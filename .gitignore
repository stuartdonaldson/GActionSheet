
# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# Test infrastructure
.auth/*
!.auth/README.md
local.settings.json
bdreport.md
# allure-results: ignore generated files; keep categories.json and history/
test-results/allure-results/*.json
!test-results/allure-results/categories.json
test-results/allure-results/environment.properties
test-results/allure-results/*-attachment.*
# ad-hoc debug logs/screenshots/junit dropped directly in test-results/ during
# investigations (e.g. `pytest ... | tee test-results/<issue>-run.log`) — not
# durable artifacts; delete when no longer needed for the active investigation.
test-results/*.log
test-results/*.xml
test-results/*.png
!test-results/probe-*.png
# junit XML output and archive
test-results/junit/
# playwright test artifacts (screenshots, videos, error-context)
test-results/playwright/
# GAS log archives (copied from Drive-mounted gasLogDir before each test run)
test-results/gas-logs/
# per-run scenario trace artifacts (scn/reporter.py: .trace.log + .trace.jsonl)
test-results/runs/
# allure and playwright HTML reports
allure-report/
playwright-report/
# TestExec-NNN/ per-invocation artifacts (np7s, scripts/run_test_exec.py) — keep
# README.md (per run) and the top-level INDEX.md, ignore the bulky generated dirs.
test-results/TestExec-*/allure-results/
test-results/TestExec-*/junit/
test-results/TestExec-*/runs/
test-results/TestExec-*/gas-logs/
test-results/TestExec-*/pytest-stdout.log
test-results/TestExec-*/allure-generate.log
node_modules/
.venv/
__pycache__/
*.pyc
.claude/worktrees/
.deploy-metadata.json
