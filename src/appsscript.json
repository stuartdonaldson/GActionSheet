{
  "timeZone": "America/New_York",
  "dependencies": {},
  "exceptionLogging": "STACKDRIVER",
  "runtimeVersion": "V8",
  "oauthScopes": [
    "https://www.googleapis.com/auth/drive",
    "https://www.googleapis.com/auth/spreadsheets",
    "https://www.googleapis.com/auth/documents",
    "https://www.googleapis.com/auth/script.scriptapp",
    "https://www.googleapis.com/auth/script.external_request",
    "https://www.googleapis.com/auth/userinfo.email",
    "https://www.googleapis.com/auth/workspace.linkpreview",
    "https://www.googleapis.com/auth/workspace.linkcreate",
    "openid"
  ],
  "urlFetchWhitelist": [
    "https://script.google.com/a/macros/northlakeuu.org/s/",
    "https://script.google.com/a/northlakeuu.org/macros/s/",
    "https://script.google.com/macros/s/",
    "https://docs.googleapis.com/",
    "https://www.googleapis.com/drive/",
    "https://api.axiom.co/"
  ],
  "webapp": {
    "access": "ANYONE_ANONYMOUS",
    "executeAs": "USER_DEPLOYING"
  },
  "addOns": {
    "common": {
      "name": "Northlake UU Tool Suite",
      "logoUrl": "https://stuartdonaldson.github.io/GActionSheet/assets/product-details/northlake-uu-emblem.png",
      "homepageTrigger": {
        "runFunction": "buildHomepageCard"
      }
    },
    "docs": {
      "homepageTrigger": {
        "runFunction": "buildHomepageCard"
      },
      "createActionTriggers": [
        {
          "id": "createAction",
          "runFunction": "createActionTrigger",
          "labelText": "Create action",
          "logoUrl": "https://stuartdonaldson.github.io/GActionSheet/assets/product-details/action-item-logo.png"
        }
      ],
      "linkPreviewTriggers": [
        {
          "labelText": "GActionSheet Action",
          "logoUrl": "https://stuartdonaldson.github.io/GActionSheet/assets/product-details/action-item-logo.png",
          "patterns": [
            {
              "hostPattern": "northlakeuu.org",
              "pathPrefix": "NUUTS"
            }
          ],
          "runFunction": "onLinkPreview"
        }
      ]
    }
  }
}
