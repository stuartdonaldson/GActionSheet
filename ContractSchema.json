{
  "actionItem": {
    "fields": [
      "action_id",
      "assignee_email",
      "action_text",
      "status"
    ]
  },
  "sheetTeamData": {
    "headers": [
      "Team Id",
      "Folder Id",
      "Contact"
    ],
    "columnsByField": {
      "team_id": 1,
      "folder_id": 2,
      "contact": 3
    }
  },
  "sheetDocData": {
    "headers": [
      "FileId",
      "Doc Name",
      "Doc Modified",
      "Doc Updated",
      "SyncStatus",
      "Team Id",
      "Action Count",
      "Resolved Count"
    ],
    "columnsByField": {
      "file_id": 1,
      "doc_name": 2,
      "doc_modified": 3,
      "doc_updated": 4,
      "sync_status": 5,
      "team_id": 6,
      "action_count": 7,
      "resolved_count": 8
    }
  },
  "sheetAction": {
    "fields": [
      "global_id",
      "file_id",
      "action_id",
      "assignee_email",
      "assignee_name",
      "action_text",
      "status",
      "document_formula",
      "doc_id",
      "doc_name",
      "created_date",
      "modified_date",
      "sync_status"
    ],
    "headers": [
      "globalId",
      "File Id",
      "ID",
      "Assignee Email",
      "Assignee Name",
      "Action",
      "Status",
      "Document",
      "Date Created",
      "Date Modified",
      "Sync Status"
    ],
    "columnsByField": {
      "global_id": 1,
      "file_id": 2,
      "action_id": 3,
      "assignee_email": 4,
      "assignee_name": 5,
      "action_text": 6,
      "status": 7,
      "document_formula": 8,
      "created_date": 9,
      "modified_date": 10,
      "sync_status": 11
    }
  },
  "webApp": {
    "routeNames": [
      "set_test_token",
      "upsert_action_rows",
      "sync_action_rows",
      "verify_action_rows",
      "mark_doc_not_found",
      "delete_action_row",
      "patch_action_status",
      "list_importable_actions",
      "run_fixture"
    ],
    "testRouteNames": [
      "edit_action_row",
      "find_sheet_actions",
      "verify_chip_integrity"
    ],
    "messages": {
      "sync_action_rows": {
        "request": [
          "action",
          "testToken",
          "docId"
        ],
        "response": [
          "ok",
          "sheetWins",
          "docWins",
          "queueDrained"
        ],
        "completionSignal": "synchronous response after ACTION_SHEET_QUEUE drains (§16.11 #4)"
      },
      "edit_action_row": {
        "request": [
          "action",
          "testToken",
          "global_id",
          "fields"
        ],
        "response": [
          "ok",
          "global_id",
          "row"
        ],
        "completionSignal": "synchronous response; row stamped Sync Status='Dirty' + Date Modified"
      },
      "patch_action_status": {
        "request": [
          "action",
          "testToken",
          "global_id",
          "status"
        ],
        "response": [
          "ok",
          "global_id"
        ],
        "completionSignal": "synchronous ack; durable status converges on the next sync_action_rows"
      },
      "delete_action_row": {
        "request": [
          "action",
          "testToken",
          "global_id"
        ],
        "response": [
          "ok",
          "global_id"
        ],
        "completionSignal": "synchronous response; row stamped Sync Status='Deleted'"
      },
      "find_sheet_actions": {
        "request": [
          "action",
          "testToken",
          "docId"
        ],
        "response": [
          "ok",
          "docId",
          "rows"
        ],
        "completionSignal": "synchronous response; rows scoped to docId"
      },
      "list_importable_actions": {
        "request": [
          "action",
          "secret",
          "docId",
          "clientVersion",
          "caller"
        ],
        "response": [
          "ok",
          "teamId",
          "rows"
        ],
        "completionSignal": "synchronous response; rows scoped to current doc's team, excluding current doc"
      }
    }
  },
  "documentRead": {
    "modelNames": [
      "floating_action",
      "tracker_row",
      "verification_sheet_row"
    ]
  }
}